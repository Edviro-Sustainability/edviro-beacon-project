{
  "name": "edviro-beacon-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:web dev:worker",
    "dev:web": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "npm run build-only && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply beacon-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply beacon-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260420.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
